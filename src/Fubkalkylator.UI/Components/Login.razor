@inject IAuthService Auth
@inject NavigationManager Nav
@using Fubkalkylator.Core

<div class="card auth-card">
    <div class="card-title">Logga in</div>

    @if (!sent)
    {
        <p class="hint">Ange din e-post så skickar vi en inloggningslänk. Klicka på länken i mejlet
            så loggas du in automatiskt.</p>
        <input type="email" class="fld" placeholder="din@epost.se" @bind="email" @bind:event="oninput" />
        <button class="btn" disabled="@(busy || email.Length < 3)" @onclick="Send">
            @(busy ? "Skickar…" : "Skicka inloggningslänk")
        </button>
    }
    else
    {
        <p class="hint">✉️ Vi skickade en inloggningslänk till <strong>@email</strong>.
            Öppna mejlet och klicka på länken — du loggas in automatiskt.</p>
        <button class="linklike" @onclick="() => { sent = false; error = null; }">Skicka igen / byt e-post</button>
    }

    @if (error is not null)
    {
        <div class="err">@error</div>
    }
</div>

@code {
    private string email = "";
    private bool sent, busy;
    private string? error;

    private async Task Send()
    {
        error = null; busy = true;
        try
        {
            await Auth.SendMagicLinkAsync(email.Trim(), Nav.BaseUri);
            sent = true;
        }
        catch (Exception ex) { error = "Kunde inte skicka länk: " + ex.Message; }
        finally { busy = false; }
    }
}
