@using Fubkalkylator.Core

<details class="card sawschedule">
    <summary>Sågschema — snittordning &amp; mått från centrum</summary>

    <p class="hint">Blockmetod (Logosol): såga de fyra sidorna med vändning emellan,
        dela sedan blocket. Måtten är avstånd från kärnan/centrum till varje snitt.</p>

    @foreach (var group in Grouped)
    {
        <div class="cut-phase">@PhaseName(group.Key)</div>
        <ol class="cut-list">
            @foreach (var cut in group)
            {
                <li>
                    <span class="cut-nr">@cut.Number</span>
                    <span class="cut-label">@cut.Label</span>
                    @if (cut.StepFromPreviousInches is double step)
                    {
                        <span class="cut-mm move">↕ flytta @Mm(step) mm</span>
                    }
                    else
                    {
                        <span class="cut-mm">@Mm(cut.DistanceFromCenterInches) mm@(Suffix(cut))</span>
                    }
                </li>
            }
        </ol>
    }
</details>

@code {
    [Parameter] public PostningResult? Result { get; set; }

    private IEnumerable<IGrouping<CutPhase, SawCut>> Grouped =>
        Result is null
            ? Enumerable.Empty<IGrouping<CutPhase, SawCut>>()
            : SawSequence.Compute(Result).GroupBy(c => c.Phase);

    private static string PhaseName(CutPhase p) => p switch
    {
        CutPhase.SideFace1 => "Sidobrädor – sida 1",
        CutPhase.SideFace2 => "Sidobrädor – sida 2 (vänd 180°)",
        CutPhase.EndFace1 => "Ändbrädor – ände 1 (vrid 90°)",
        CutPhase.EndFace2 => "Ändbrädor – ände 2 (vänd 180°)",
        CutPhase.BlockSplit => "Delning av blocket",
        _ => "",
    };

    private static string Mm(double inches) => (inches * SawConstants.MmPerInch).ToString("0");
    private static string Suffix(SawCut c) => c.AboveCenter is bool a ? (a ? " ovan centrum" : " under centrum") : " från centrum";
}
