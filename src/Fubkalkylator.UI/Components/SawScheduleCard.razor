@inject SawSettings Saw
@using Fubkalkylator.Core

<details class="card sawschedule">
    <summary>Sågschema — snittordning &amp; mått</summary>

    <p class="hint">Följer vald sågordning (ändras under "Stega igenom snitten").
        Första snittet på varje sida är från centrum, resten "flytta X mm" från förra snittet.</p>

    <ol class="cut-list">
        @foreach (var cut in Cuts)
        {
            <li>
                <span class="cut-nr">@cut.Number</span>
                <span class="cut-label">@cut.Label</span>
                @if (cut.StepFromPreviousInches is double s)
                {
                    <span class="cut-mm move">↕ flytta @Mm(s) mm</span>
                }
                else
                {
                    <span class="cut-mm">@Mm(cut.DistanceFromCenterInches) mm@(Suffix(cut))</span>
                }
            </li>
        }
    </ol>
</details>

@code {
    [Parameter] public PostningResult? Result { get; set; }

    /// <summary>Blockets uppdelning (t.ex. måldimension). Null = blockets standardsnitt (1"/2").</summary>
    [Parameter] public IReadOnlyList<Piece>? BlockPieces { get; set; }

    private IReadOnlyList<SawCut> Cuts =>
        Result is null ? Array.Empty<SawCut>() : SawSequence.Compute(Result, Saw.SawMethod, EffectiveBlock());

    private IReadOnlyList<Piece>? EffectiveBlock()
    {
        if (Result is null || !Saw.CenterCutThroughPith || Saw.SawMethod == SawMethod.Genomsagning)
            return BlockPieces;
        var baseBlock = BlockPieces ?? PostningLayout.BlockPieces(Result);
        if (baseBlock.Count == 0) return BlockPieces;
        return PostningLayout.CenteredBlockPieces(Result.BlockHeight.Inches, baseBlock[0].Thickness, Result.KerfInches);
    }

    private static string Mm(double inches) => (inches * SawConstants.MmPerInch).ToString("0");
    private static string Suffix(SawCut c) => c.AboveCenter is bool a ? (a ? " ovan centrum" : " under centrum") : " från centrum";
}
