@inject SawSettings Saw
@inject IAuthService Auth
@inject IJSRuntime JS
@using System.Globalization
@using Fubkalkylator.Core

<div class="profile">
    <button class="theme-toggle" @onclick="Toggle" title="Profil &amp; inställningar" aria-label="Profil och inställningar">👤</button>

    @if (open)
    {
        <div class="profile-backdrop" @onclick="Close"></div>
        <div class="profile-menu">
            @if (Auth.Email is not null)
            {
                <div class="profile-email">Inloggad som<br /><strong>@Auth.Email</strong></div>
            }

            <div class="profile-section">
                <div class="profile-section-title">Enhet</div>
                <div class="seg small">
                    <button type="button" class="@(!Saw.UseInches ? "on" : null)" @onclick="() => SetUnits(false)">mm/cm</button>
                    <button type="button" class="@(Saw.UseInches ? "on" : null)" @onclick="() => SetUnits(true)">tum</button>
                </div>
            </div>

            <div class="profile-section">
                <div class="profile-section-title">Såginställningar</div>
                <label>Sågspår
                    <span class="value-box sm">
                        <input type="number" step="any" min="0" @bind="Kerf" @bind:event="oninput" />
                        <span class="unit">@UnitSym</span>
                    </span>
                </label>
                <label>Stockklämma
                    <span class="value-box sm">
                        <input type="number" step="any" min="0" @bind="Clamp" @bind:event="oninput" />
                        <span class="unit">@UnitSym</span>
                    </span>
                </label>
            </div>

            @if (Auth.Email is not null)
            {
                <button class="btn ghost sm" @onclick="Logout">Logga ut</button>
            }
        </div>
    }
</div>

@code {
    private bool open;
    private bool ready;

    private void Toggle() => open = !open;
    private void Close() => open = false;

    private string UnitSym => Units.Symbol(Saw, MetricUnit.Mm);

    // Sågspåret lagras i tum, klämman i mm — visas i vald enhet.
    private double Kerf
    {
        get => Units.ToDisplay(Saw.KerfInches, Saw, MetricUnit.Mm);
        set
        {
            Saw.KerfInches = Math.Max(0.02, Units.FromDisplay(value, Saw, MetricUnit.Mm));
            Persist("kerfMm", Saw.KerfInches * SawConstants.MmPerInch);
            Saw.RaiseChanged();
        }
    }

    private double Clamp
    {
        get => Units.ToDisplay(Saw.ClampHeightMm / SawConstants.MmPerInch, Saw, MetricUnit.Mm);
        set
        {
            Saw.ClampHeightMm = Math.Max(0, Units.FromDisplay(value, Saw, MetricUnit.Mm) * SawConstants.MmPerInch);
            Persist("clampMm", Saw.ClampHeightMm);
            Saw.RaiseChanged();
        }
    }

    private void SetUnits(bool inches)
    {
        Saw.UseInches = inches;
        if (ready) _ = JS.InvokeVoidAsync("appStore.set", "useInches", inches ? "1" : "0");
        Saw.RaiseChanged();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var k = await JS.InvokeAsync<string?>("appStore.get", "kerfMm");
        if (double.TryParse(k, NumberStyles.Any, CultureInfo.InvariantCulture, out var km) && km > 0)
            Saw.KerfInches = km / SawConstants.MmPerInch;
        var c = await JS.InvokeAsync<string?>("appStore.get", "clampMm");
        if (double.TryParse(c, NumberStyles.Any, CultureInfo.InvariantCulture, out var cm) && cm >= 0)
            Saw.ClampHeightMm = cm;
        var u = await JS.InvokeAsync<string?>("appStore.get", "useInches");
        if (u is "1" or "0") Saw.UseInches = u == "1";
        ready = true;
        Saw.RaiseChanged();   // så öppna sidor räknar om med de laddade värdena
        StateHasChanged();
    }

    private void Persist(string key, double value)
    {
        if (ready) _ = JS.InvokeVoidAsync("appStore.set", key, value.ToString(CultureInfo.InvariantCulture));
    }

    private async Task Logout()
    {
        open = false;
        await Auth.SignOutAsync();
    }
}
