@inject IAuthService Auth
@inject NavigationManager Nav
@implements IDisposable
@using Fubkalkylator.Core

@if (!ready)
{
    <div class="auth-loading">Laddar…</div>
}
else if (Auth.IsSignedIn)
{
    @ChildContent
}
else
{
    <Login />
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool ready;

    protected override async Task OnInitializedAsync()
    {
        Auth.Changed += OnChanged;
        await Auth.InitializeAsync();

        // Återvändande magisk länk? Token ligger i URL:ens fragment (#access_token=…).
        if (!Auth.IsSignedIn && Nav.Uri.Contains("access_token", StringComparison.Ordinal))
        {
            if (await Auth.TrySignInFromUrlAsync(Nav.Uri))
                Nav.NavigateTo(Nav.BaseUri, forceLoad: false);   // rensa bort token ur adressfältet
        }

        ready = true;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Auth.Changed -= OnChanged;
}
