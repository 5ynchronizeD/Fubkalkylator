@inject SawSettings Saw
@inject IJSRuntime JS
@using System.Globalization
@using Fubkalkylator.Core

<details class="card stepsaw">
    <summary>Stega igenom snitten</summary>

    @if (Result is not null)
    {
        <div class="stepsaw-method">
            <label for="sawmethod">Sågordning</label>
            <select id="sawmethod" class="fld" @bind="Method" @bind:event="onchange">
                <option value="@SawMethod.Block180">Blocksågning</option>
                <option value="@SawMethod.Varv90">Varvsågning</option>
                <option value="@SawMethod.Genomsagning">Genomsågning</option>
            </select>
        </div>
        <label class="stepsaw-pith">
            <input type="checkbox" @bind="CenterPith" @bind:event="onchange"
                   disabled="@(Saw.SawMethod == SawMethod.Genomsagning)" />
            Snitt genom kärnan (märgdelning)
        </label>
        <label class="stepsaw-clamp">
            Stockklämma
            <span class="value-box sm">
                <input type="number" step="1" min="0" max="200" @bind="Clamp" @bind:event="onchange" />
                <span class="unit">mm</span>
            </span>
            <span class="muted">minsta bottenbräda (0 = ingen)</span>
        </label>

        <div class="stepsaw-stage">
            <div class="stepsaw-rot" style="transform: rotate(@Deg(Angle)deg);">
                @((MarkupString)CrossSectionSvg.RenderStepped(EffR!, step, Saw.SawMethod, revealCut, EffPieces))
            </div>
        </div>

        <div class="barkstate @(BarkDownNow ? "down" : "ok")">
            @if (BarkDownNow)
            {
                <span>▲ <strong>Bark nedåt</strong> — lyft toppänden (se topphöjning nedan)</span>
            }
            else
            {
                <span>✓ <strong>Plan yta nedåt</strong> — ingen topphöjning för det här snittet</span>
            }
        </div>

        <div class="stepsaw-info">
            @if (step == 0)
            {
                <strong>Hel stock</strong>
                <span class="muted">Tryck Nästa för att börja såga.</span>
            }
            else
            {
                var cut = cuts[step - 1];
                <strong>@step/@cuts.Count · @(Saw.SawMethod == SawMethod.Genomsagning ? "Genomsågning" : FaceName(cut.Face))</strong>
                <span class="cut-label">@cut.Label</span>
                @if (cut.StepFromPreviousInches is double s)
                {
                    <span class="cut-mm move">↕ flytta @Mm(s) mm</span>
                }
                else
                {
                    <span class="cut-mm">@Mm(cut.DistanceFromCenterInches) mm@(Suffix(cut))</span>
                }
            }
        </div>

        <div class="stepsaw-controls">
            <button class="btn ghost" disabled="@(step == 0)" @onclick="Prev">‹ Föregående</button>
            <button class="btn" disabled="@(step >= cuts.Count)" @onclick="Next">Nästa ›</button>
            <button class="linklike" disabled="@(step == 0)" @onclick="Reset">Återställ</button>
        </div>
        <p class="hint">Bilden roterar så att sidan som sågas hamnar uppåt (sågen snittar alltid uppåt) —
            snittlinjen och måttet visas när stocken vänts rätt. Bortsågat följer den nya formen.</p>

        <ToeBoardCard BarkDown="@BarkDownNow" />
    }
</details>

@code {
    [Parameter] public PostningResult? Result { get; set; }

    /// <summary>Blockets uppdelning (t.ex. måldimension). Null = blockets standardsnitt (1"/2").</summary>
    [Parameter] public IReadOnlyList<Piece>? BlockPieces { get; set; }

    private int step;
    private bool revealCut = true;
    private int revealToken;
    private IReadOnlyList<SawCut> cuts = Array.Empty<SawCut>();

    // Effektiv postning + blockuppdelning: vid märgdelning krymper blocket till ett
    // band av hela reglar centrerat på märgen (sido-/ändbrädor följer nya kanten).
    private PostningResult? EffR;
    private IReadOnlyList<Piece>? EffPieces;

    protected override void OnParametersSet() => Recompute();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        bool changed = false;
        var s = await JS.InvokeAsync<string?>("appStore.get", "sawMethod");
        if (int.TryParse(s, out var m) && Enum.IsDefined(typeof(SawMethod), m) && (SawMethod)m != Saw.SawMethod)
        {
            Saw.SawMethod = (SawMethod)m;
            changed = true;
        }
        var cp = await JS.InvokeAsync<string?>("appStore.get", "centerPith");
        if (cp is "1" or "0" && (cp == "1") != Saw.CenterCutThroughPith)
        {
            Saw.CenterCutThroughPith = cp == "1";
            changed = true;
        }
        var cl = await JS.InvokeAsync<string?>("appStore.get", "clampMm");
        if (double.TryParse(cl, NumberStyles.Any, CultureInfo.InvariantCulture, out var clamp)
            && clamp >= 0 && clamp <= 200 && Math.Abs(clamp - Saw.ClampHeightMm) > 1e-9)
        {
            Saw.ClampHeightMm = clamp;
            changed = true;
        }
        if (changed)
        {
            Recompute();
            StateHasChanged();
        }
    }

    private double ClampInches => Saw.ClampHeightMm / SawConstants.MmPerInch;

    // Räknar om effektiv postning, block och snittordning.
    private void Recompute()
    {
        ComputeEffective();
        cuts = EffR is null ? Array.Empty<SawCut>() : SawSequence.Compute(EffR, Saw.SawMethod, EffPieces, ClampInches);
        if (step > cuts.Count) step = cuts.Count;
    }

    private void ComputeEffective()
    {
        EffR = Result;
        EffPieces = BlockPieces;
        if (Result is null || !Saw.CenterCutThroughPith || Saw.SawMethod == SawMethod.Genomsagning) return;

        var baseBlock = BlockPieces ?? PostningLayout.BlockPieces(Result);
        if (baseBlock.Count == 0) return;

        var centered = PostningLayout.CenteredBlock(Result, baseBlock[0].Thickness);
        if (centered is null) { EffPieces = baseBlock; return; }
        EffR = centered.Value.Result;
        EffPieces = centered.Value.Pieces;
    }

    private double Angle => step == 0 ? 0 : cuts[step - 1].RotationDegrees;

    // Bark nedåt just nu? (rund sida vilar mot bädden → topphöjning aktuell)
    private bool BarkDownNow => EffR is not null && SawSequence.IsBarkDown(EffR, step, Saw.SawMethod, EffPieces, ClampInches);

    private async Task Next() { if (step < cuts.Count) { step++; await RotateThenReveal(); } }
    private async Task Prev() { if (step > 0) { step--; await RotateThenReveal(); } }
    private void Reset() { step = 0; revealCut = true; }

    private SawMethod Method { get => Saw.SawMethod; set => SetMethod(value); }

    private void SetMethod(SawMethod m)
    {
        Saw.SawMethod = m;
        _ = JS.InvokeVoidAsync("appStore.set", "sawMethod", ((int)m).ToString(CultureInfo.InvariantCulture));
        step = 0;
        revealCut = true;
        Recompute();
    }

    private bool CenterPith
    {
        get => Saw.CenterCutThroughPith;
        set
        {
            Saw.CenterCutThroughPith = value;
            _ = JS.InvokeVoidAsync("appStore.set", "centerPith", value ? "1" : "0");
            step = 0;
            revealCut = true;
            Recompute();
        }
    }

    private double Clamp
    {
        get => Saw.ClampHeightMm;
        set
        {
            Saw.ClampHeightMm = Math.Max(0, value);
            _ = JS.InvokeVoidAsync("appStore.set", "clampMm", Saw.ClampHeightMm.ToString(CultureInfo.InvariantCulture));
            step = 0;
            revealCut = true;
            Recompute();
        }
    }

    // Rotera först (dölj snittet), visa snittlinjen efter att rotationen animerat klart.
    private async Task RotateThenReveal()
    {
        int token = ++revealToken;
        revealCut = false;
        StateHasChanged();
        await Task.Delay(560);
        if (token == revealToken) { revealCut = true; StateHasChanged(); }
    }

    private static string FaceName(SawFace f) => f switch
    {
        SawFace.Top or SawFace.Bottom => "Ände (topp/botten)",
        SawFace.Left or SawFace.Right => "Sida",
        _ => "Delning av blocket",
    };

    private static string Deg(double v) => v.ToString("0.#", CultureInfo.InvariantCulture);
    private static string Mm(double inches) => (inches * SawConstants.MmPerInch).ToString("0");
    private static string Suffix(SawCut c) => c.AboveCenter is bool a ? (a ? " ovan centrum" : " under centrum") : " från centrum";
}
