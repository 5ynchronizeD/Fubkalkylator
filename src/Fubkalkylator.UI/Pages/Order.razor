@page "/order"
@implements IDisposable
@inject SawSettings Saw
@inject IJSRuntime JS
@using System.Globalization
@using System.Text.Json

<PageTitle>Orderlista</PageTitle>

<div class="page-head">
    <h1>Orderlista</h1>
    <p>Lägg in dimensionerna du behöver — appen räknar fram minsta stock och antal stockar per rad.</p>
</div>

<div class="card">
    <div class="table-scroll">
    <table class="order-table">
        <thead>
            <tr>
                <th>Tjocklek (@LenSym)</th><th>Bredd (@LenSym)</th><th>Längd (@LenSym)</th><th>Antal</th>
                <th>Minsta stock</th><th>Bitar/stock</th><th>Stockar</th><th></th>
            </tr>
        </thead>
        <tbody>
            @if (rows.Count == 0)
            {
                <tr class="empty-row"><td colspan="8" class="na">Inga rader ännu — tryck ＋ Lägg till rad.</td></tr>
            }
            @for (int i = 0; i < rows.Count; i++)
            {
                var row = rows[i];
                var line = plan is not null && i < plan.Lines.Count ? plan.Lines[i] : null;
                <tr @key="row">
                    <td><input type="number" step="any" min="0" value="@Disp(row.ThickMm)" @onchange="e => SetDim(row, 't', e.Value)" /></td>
                    <td><input type="number" step="any" min="0" value="@Disp(row.WidthMm)" @onchange="e => SetDim(row, 'w', e.Value)" /></td>
                    <td><input type="number" step="any" min="0" value="@Disp(row.LengthMm)" @onchange="e => SetDim(row, 'l', e.Value)" /></td>
                    <td><input type="number" step="1" min="0" max="9999" @bind="row.Qty" @bind:event="oninput" @bind:after="Recalculate" /></td>
                    @if (line?.Achievable == true)
                    {
                        <td>@FubDisp(line.Target!.Postning.DiameterUnderBark) fub</td>
                        <td>@line.PiecesPerLog st</td>
                        <td><strong>@line.LogsNeeded st</strong></td>
                    }
                    else
                    {
                        <td colspan="3" class="na">går inte inom 20" stock</td>
                    }
                    <td><button class="linklike danger" @onclick="() => RemoveRow(row)">✕</button></td>
                </tr>
            }
        </tbody>
        @if (plan is not null && plan.Lines.Any(l => l.Achievable))
        {
            <tfoot>
                <tr class="sum"><td colspan="6">Totalt antal stockar</td><td><strong>@plan.TotalLogs st</strong></td><td></td></tr>
            </tfoot>
        }
    </table>
    </div>

    <div class="order-actions">
        <button class="btn ghost sm" @onclick="AddRow">＋ Lägg till rad</button>
    </div>
    <p class="hint">Måtten anges i vald enhet (ändra i profilmenyn). Minsta stock anges som fub (under bark). En stock antas ge en postning.</p>
</div>

@code {
    // Mått lagras i mm; visas i vald global enhet.
    private string LenSym => Units.Symbol(Saw, MetricUnit.Mm);
    private double Disp(double mm) => Units.ToDisplay(mm / SawConstants.MmPerInch, Saw, MetricUnit.Mm);
    private string FubDisp(Measure m) => Saw.UseInches ? $"{m.Inches:0.##}\"" : $"{m.Centimeters:0.#} cm";

    private void SetDim(Row row, char which, object? v)
    {
        if (!double.TryParse(Convert.ToString(v, CultureInfo.InvariantCulture), NumberStyles.Any, CultureInfo.InvariantCulture, out var d))
            return;
        double mm = Math.Max(0, Units.FromDisplay(d, Saw, MetricUnit.Mm) * SawConstants.MmPerInch);
        if (which == 't') row.ThickMm = mm;
        else if (which == 'w') row.WidthMm = mm;
        else row.LengthMm = mm;
        Recalculate();
    }

    private sealed class Row
    {
        public double ThickMm { get; set; } = 45;
        public double WidthMm { get; set; } = 95;
        public double LengthMm { get; set; } = 3600;
        public int Qty { get; set; } = 10;
    }

    private List<Row> rows = new();
    private OrderPlan? plan;
    private bool ready;

    protected override void OnInitialized()
    {
        Saw.Changed += OnSettingsChanged;   // sågspår ändras i profilmenyn
        Recalculate();
    }

    private void OnSettingsChanged() { Recalculate(); StateHasChanged(); }

    public void Dispose() => Saw.Changed -= OnSettingsChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var s = await JS.InvokeAsync<string?>("appStore.get", "orderRows");
        if (!string.IsNullOrEmpty(s))
        {
            try
            {
                var loaded = JsonSerializer.Deserialize<List<Row>>(s);
                if (loaded is { Count: > 0 }) { rows = loaded; Recalculate(); StateHasChanged(); }
            }
            catch { /* ignorera trasig cache */ }
        }
        ready = true;
    }

    private void AddRow() { rows.Add(new Row()); Recalculate(); }
    private void RemoveRow(Row row) { rows.Remove(row); Recalculate(); }

    private void Recalculate()
    {
        var items = rows.Select(r => new OrderItem
        {
            ThicknessInches = Math.Max(0, r.ThickMm) / SawConstants.MmPerInch,
            WidthInches = Math.Max(0, r.WidthMm) / SawConstants.MmPerInch,
            Quantity = Math.Max(0, r.Qty),
        });
        plan = OrderPlanner.Plan(items, Saw.KerfInches);
        Persist();
    }

    private void Persist()
    {
        if (ready)
            _ = JS.InvokeVoidAsync("appStore.set", "orderRows", JsonSerializer.Serialize(rows));
    }

    private static string Cm(Measure m) => $"{m.Centimeters:0.#} cm ({m.Inches:0.##}\")";
}
