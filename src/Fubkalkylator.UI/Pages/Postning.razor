@page "/"
@page "/postning"
@page "/mal"
@implements IDisposable
@inject SawSettings Saw
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Globalization
@using System.Text.Json

<PageTitle>Postning</PageTitle>

<div class="page-head">
    <h1>Postning</h1>
    <p>Utgå från stocken du har: se den optimala postningen — eller ange en dimension
        och få veta hur många bitar du får ut. Samma ritning, material och snittgenomgång.</p>
</div>

<div class="seg mode">
    <button type="button" class="@(mode == Mode.Optimal ? "on" : null)" @onclick="() => SetMode(Mode.Optimal)">Optimalt ur stocken</button>
    <button type="button" class="@(mode == Mode.Fit ? "on" : null)" @onclick="() => SetMode(Mode.Fit)">Få ut en dimension</button>
</div>

<div class="input-bar">
    <div class="bar-top">
        <label for="fub">Stockens diameter [fub]</label>
        <div class="seg small">
            <button type="button" class="@(unit == Unit.Inch ? "on" : null)" @onclick="() => SetUnit(Unit.Inch)">tum</button>
            <button type="button" class="@(unit == Unit.Mm ? "on" : null)" @onclick="() => SetUnit(Unit.Mm)">mm</button>
        </div>
    </div>
    <div class="stepper">
        <button type="button" @onclick="() => Nudge(-1)" aria-label="Minska">−</button>
        <div class="value-box">
            <input id="fub" type="number" step="@Step" min="@DispMin" max="@DispMax" @bind="FubDisplay" @bind:event="oninput" />
            <span class="unit">@UnitSym</span>
        </div>
        <button type="button" @onclick="() => Nudge(1)" aria-label="Öka">+</button>
    </div>
    @if (stockError is not null)
    {
        <div class="err">@stockError</div>
    }
    else
    {
        <div class="sub">≈ @Other(fub)</div>
    }

    @if (mode == Mode.Fit)
    {
        <div class="target-row">
            <span class="times">→</span>
            <div class="dim-field">
                <div class="value-box">
                    <input type="number" step="@Step" min="@TMin" max="@TMax" disabled="@thicknessAny"
                           @bind="ThicknessDisplay" @bind:event="oninput" />
                    <span class="unit">@UnitSym</span>
                </div>
                <small>tjock @(thicknessAny ? "" : $"· {Other(thickness)}")</small>
                <label class="any"><input type="checkbox" @bind="ThicknessAny" /> spelar ingen roll</label>
            </div>
            <span class="times">×</span>
            <div class="dim-field">
                <div class="value-box">
                    <input type="number" step="@Step" min="@WMin" max="@WMax" disabled="@widthAny"
                           @bind="WidthDisplay" @bind:event="oninput" />
                    <span class="unit">@UnitSym</span>
                </div>
                <small>bred @(widthAny ? "" : $"· {Other(width)}")</small>
                <label class="any"><input type="checkbox" @bind="WidthAny" /> spelar ingen roll</label>
            </div>
        </div>
    }
</div>

@if (stockError is not null)
{
    <!-- felet visas i inmatningen ovan -->
}
else if (mode == Mode.Optimal)
{
    @if (stockResult is not null)
    {
        <PostningResultView Result="stockResult" />
    }
}
else if (thicknessAny)
{
    @if (myCant is not null)
    {
        <div class="banner">
            Ur din stock (@U((Measure)fub) fub) blir blocket <strong>@U(myCant.BlockWidth) × @U(myCant.BlockHeight)</strong> — klyv i valfri tjocklek.
        </div>
        <PostningResultView Result="myCant" Target="BlockOnlyTarget" />
    }
}
else if (fit is not null && !fit.WidthFits)
{
    <div class="banner warn">
        @U(width) är för brett för den här stocken. Största bredd du får ur blocket är <strong>@U(fit.MaxWidth)</strong>.
    </div>
}
else if (fit is not null)
{
    <div class="banner">
        Ur din stock (@U((Measure)fub) fub) får du <strong>@fit.PieceCount st @DimFor(FitWidth)</strong>.
        @if (fit.TrimWidthInches > 0.001)
        {
            <span class="trim">Blocket är @U(fit.MaxWidth) brett – kapas @U((Measure)fit.TrimWidthInches) till målbredd.</span>
        }
    </div>
    <PostningResultView Result="fit.Postning" BlockPieces="fit.BlockPieces" Target="FitTarget" />
}

@code {
    private enum Mode { Optimal, Fit }
    private enum Unit { Inch, Mm }

    private Mode mode = Mode.Optimal;
    private Unit unit = Unit.Inch;
    private bool ready;

    private double fub = 9.75;
    private double width = 6, thickness = 2;
    private bool widthAny, thicknessAny;

    private PostningResult? stockResult;
    private string? stockError;
    private FitResult? fit;
    private PostningResult? myCant;

    private double FitWidth => widthAny && fit is not null ? fit.MaxWidth.Inches : width;

    private PostningResultView.TargetSpec FitTarget => fit is null
        ? default!
        : new(thickness, FitWidth, fit.PieceCount, DimFor(FitWidth), BlockOnly: false);

    private static readonly PostningResultView.TargetSpec BlockOnlyTarget = new(0, 0, 0, "block", BlockOnly: true);

    // ---- enheter ----
    private string UnitSym => unit == Unit.Mm ? "mm" : "\"";
    private double Step => unit == Unit.Mm ? 1 : 0.25;
    private double DispMin => unit == Unit.Mm ? 50 : 2;
    private double DispMax => unit == Unit.Mm ? 510 : 20;
    private double TMin => unit == Unit.Mm ? 13 : 0.5;
    private double TMax => unit == Unit.Mm ? 300 : 12;
    private double WMin => unit == Unit.Mm ? 13 : 0.5;
    private double WMax => unit == Unit.Mm ? 520 : 20;

    private static double Round(double v) => Math.Round(v, 2);
    private double ToDisplay(double inch) => unit == Unit.Mm ? inch * SawConstants.MmPerInch : inch;
    private double FromDisplay(double disp) => unit == Unit.Mm ? disp / SawConstants.MmPerInch : disp;

    private double FubDisplay
    {
        get => unit == Unit.Mm ? Math.Round(fub * SawConstants.MmPerInch) : Math.Round(fub, 2);
        set { fub = unit == Unit.Mm ? value / SawConstants.MmPerInch : value; Recalculate(); }
    }
    private double ThicknessDisplay { get => Round(ToDisplay(thickness)); set { thickness = FromDisplay(value); Recalculate(); } }
    private double WidthDisplay { get => Round(ToDisplay(width)); set { width = FromDisplay(value); Recalculate(); } }

    private string U(Measure m) => unit == Unit.Mm ? $"{m.Millimeters:0} mm" : $"{m.Inches:0.##}\"";
    private string Other(double inch) => unit == Unit.Mm ? $"{inch:0.##}\"" : $"{inch * SawConstants.MmPerInch:0.#} mm";
    private string DimFor(double w) => $"{U(thickness)}×{U((Measure)w)}";

    private bool WidthAny { get => widthAny; set { widthAny = value; Recalculate(); } }
    private bool ThicknessAny { get => thicknessAny; set { thicknessAny = value; Recalculate(); } }

    protected override void OnInitialized()
    {
        Saw.Changed += OnSettingsChanged;
        if (Nav.Uri.Contains("/mal", StringComparison.OrdinalIgnoreCase)) mode = Mode.Fit;
        Recalculate();
    }

    private void OnSettingsChanged() { Recalculate(); StateHasChanged(); }
    public void Dispose() => Saw.Changed -= OnSettingsChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var s = await JS.InvokeAsync<string?>("appStore.get", "pmState");
        if (!string.IsNullOrEmpty(s))
        {
            try
            {
                var d = JsonSerializer.Deserialize<State>(s);
                if (d is not null)
                {
                    if (!Nav.Uri.Contains("/mal", StringComparison.OrdinalIgnoreCase)) mode = (Mode)d.Mode;
                    unit = (Unit)d.U; fub = d.Fub; thickness = d.T; width = d.W;
                    thicknessAny = d.TA; widthAny = d.WA;
                }
            }
            catch { /* ignorera trasig cache */ }
        }
        ready = true;
        Recalculate();
        StateHasChanged();
    }

    private void SetMode(Mode m) { mode = m; Recalculate(); }
    private void SetUnit(Unit u) { unit = u; Persist(); }

    private void Nudge(int dir)
    {
        if (unit == Unit.Mm)
        {
            double mm = Math.Round(fub * SawConstants.MmPerInch) + dir * 5;
            fub = Math.Clamp(mm, 50, 510) / SawConstants.MmPerInch;
        }
        else
        {
            double inch = Math.Round((fub + dir * 0.25) / 0.25) * 0.25;
            fub = Math.Clamp(inch, 2, 20);
        }
        Recalculate();
    }

    private void Recalculate()
    {
        Persist();
        stockResult = null; stockError = null; fit = null; myCant = null;

        double clamp = Saw.ClampHeightMm / SawConstants.MmPerInch;

        PostningResult p;
        try { p = PostningsMax.Compute(fub, Saw.KerfInches, clamp); }
        catch (ArgumentOutOfRangeException)
        {
            stockError = "Stocken är för klen för att ge ett block. Ange en grövre stock.";
            return;
        }

        if (mode == Mode.Optimal) { stockResult = p; return; }

        // Fit-läget: få ut en dimension ur stocken.
        if (thicknessAny) { myCant = p; return; }
        double w = widthAny ? p.BlockWidth.Inches : width;
        if (w > 0 && thickness > 0)
            fit = TargetDimension.FitInStock(fub, w, thickness, Saw.KerfInches);
    }

    private void Persist()
    {
        if (!ready) return;
        var d = new State { Mode = (int)mode, U = (int)unit, Fub = fub, T = thickness, W = width, TA = thicknessAny, WA = widthAny };
        _ = JS.InvokeVoidAsync("appStore.set", "pmState", JsonSerializer.Serialize(d));
    }

    private sealed class State
    {
        public int Mode { get; set; }
        public int U { get; set; }
        public double Fub { get; set; } = 9.75;
        public double T { get; set; } = 2;
        public double W { get; set; } = 6;
        public bool TA { get; set; }
        public bool WA { get; set; }
    }
}
