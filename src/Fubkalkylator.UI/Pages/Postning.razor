@page "/"
@page "/postning"
@page "/mal"
@implements IDisposable
@inject SawSettings Saw
@inject IJSRuntime JS
@inject NavigationManager Nav
@using System.Globalization
@using System.Text.Json

<PageTitle>Postning</PageTitle>

<div class="page-head">
    <h1>Postning</h1>
    <p>Utgå från en stock du har — eller från dimensionen du vill ha. Samma ritning,
        material och snittgenomgång oavsett håll.</p>
</div>

<div class="seg mode">
    <button type="button" class="@(mode == Mode.Stock ? "on" : null)" @onclick="() => SetMode(Mode.Stock)">Jag har en stock</button>
    <button type="button" class="@(mode == Mode.Dim ? "on" : null)" @onclick="() => SetMode(Mode.Dim)">Jag vill ha en dimension</button>
</div>

@if (mode == Mode.Stock)
{
    <div class="input-bar">
        <div class="bar-top">
            <label for="fub">Diameter under bark [fub]</label>
            <div class="seg small">
                <button type="button" class="@(unit == Unit.Inch ? "on" : null)" @onclick="() => SetUnit(Unit.Inch)">tum</button>
                <button type="button" class="@(unit == Unit.Mm ? "on" : null)" @onclick="() => SetUnit(Unit.Mm)">mm</button>
            </div>
        </div>
        <div class="stepper">
            <button type="button" @onclick="() => Nudge(-1)" aria-label="Minska">−</button>
            <div class="value-box">
                <input id="fub" type="number" step="@Step" min="@DispMin" max="@DispMax" @bind="FubDisplay" @bind:event="oninput" />
                <span class="unit">@UnitSym</span>
            </div>
            <button type="button" @onclick="() => Nudge(1)" aria-label="Öka">+</button>
        </div>
        @if (stockError is not null)
        {
            <div class="err">@stockError</div>
        }
        else
        {
            <div class="sub">≈ @Other(fub)</div>
        }
    </div>

    @if (stockResult is not null)
    {
        <PostningResultView Result="stockResult" />
    }
}
else
{
    <div class="input-bar">
        <div class="bar-top">
            <label>Jag vill ha</label>
            <div class="seg small">
                <button type="button" class="@(unit == Unit.Inch ? "on" : null)" @onclick="() => SetUnit(Unit.Inch)">tum</button>
                <button type="button" class="@(unit == Unit.Mm ? "on" : null)" @onclick="() => SetUnit(Unit.Mm)">mm</button>
            </div>
        </div>
        <div class="target-row">
            <div class="dim-field">
                <div class="value-box">
                    <input type="number" step="@Step" min="@TMin" max="@TMax" disabled="@thicknessAny"
                           @bind="ThicknessDisplay" @bind:event="oninput" />
                    <span class="unit">@UnitSym</span>
                </div>
                <small>tjock @(thicknessAny ? "" : $"· {Other(thickness)}")</small>
                <label class="any"><input type="checkbox" @bind="ThicknessAny" /> spelar ingen roll</label>
            </div>
            <span class="times">×</span>
            <div class="dim-field">
                <div class="value-box">
                    <input type="number" step="@Step" min="@WMin" max="@WMax" disabled="@widthAny"
                           @bind="WidthDisplay" @bind:event="oninput" />
                    <span class="unit">@UnitSym</span>
                </div>
                <small>bred @(widthAny ? "" : $"· {Other(width)}")</small>
                <label class="any"><input type="checkbox" @bind="WidthAny" /> spelar ingen roll</label>
            </div>
        </div>
    </div>

    @if (thicknessAny && widthAny)
    {
        <div class="banner warn">Ange minst ett mått — annars finns inget att optimera.</div>
    }
    else if (widthAny)
    {
        @if (widthTable is { Count: > 0 })
        {
            <div class="banner">Bredden är fri. Välj en bredd nedan för att se ritningen.</div>
            <div class="card">
                <div class="card-title">Alternativ · @U(thickness) tjocka bitar</div>
                <table class="opt">
                    <thead><tr><th>Bredd</th><th>Minsta stock</th><th>Antal</th><th>Utbyte</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var row in widthTable)
                        {
                            <tr @onclick="() => PickWidth(row.ActualBlockWidth.Inches)">
                                <td>@U(row.ActualBlockWidth)</td>
                                <td>@U(row.Postning.DiameterUnderBark)</td>
                                <td>@row.TargetPieceCount st</td>
                                <td>@Yield(row) %</td>
                                <td class="go">visa ›</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="banner warn">Den tjockleken går inte att få ut inom @U((Measure)20.0) stock.</div>
        }
    }
    else if (thicknessAny)
    {
        @if (cant is not null)
        {
            <div class="banner">
                Minsta stock för <strong>@U(width) bred</strong> är <strong>@U(cant.DiameterUnderBark) fub</strong>.
                Blocket kan klyvas i valfri tjocklek.
            </div>
            <PostningResultView Result="cant" Target="BlockOnlyTarget" />
        }
        else
        {
            <div class="banner warn">Den bredden går inte att få ut inom @U((Measure)20.0) stock.</div>
        }
    }
    else if (result is not null)
    {
        <div class="banner">
            Du får <strong>@result.TargetPieceCount st @Dim</strong> ur en stock på
            minst <strong>@U(result.Postning.DiameterUnderBark) fub</strong>.
            @if (result.TrimWidthInches > 0.001)
            {
                <span class="trim">Blocket blir @U(result.ActualBlockWidth) brett – kapas @U((Measure)result.TrimWidthInches) till målbredd.</span>
            }
        </div>
        <PostningResultView Result="result.Postning" BlockPieces="result.BlockPieces" Target="ResultTarget" />
    }
    else
    {
        <div class="banner warn">Den dimensionen går inte att få ut inom @U((Measure)20.0) stock. Prova mindre mått.</div>
    }
}

@code {
    private enum Mode { Stock, Dim }
    private enum Unit { Inch, Mm }

    private Mode mode = Mode.Stock;
    private Unit unit = Unit.Inch;
    private bool ready;

    // Stock-läget
    private double fub = 9.75;
    private PostningResult? stockResult;
    private string? stockError;

    // Dimension-läget
    private double width = 6, thickness = 2;
    private bool widthAny, thicknessAny;
    private TargetResult? result;
    private IReadOnlyList<TargetResult>? widthTable;
    private PostningResult? cant;

    private PostningResultView.TargetSpec ResultTarget => result is null
        ? default!
        : new(thickness, result.TargetWidth.Inches, result.TargetPieceCount, Dim, BlockOnly: false);

    private static readonly PostningResultView.TargetSpec BlockOnlyTarget = new(0, 0, 0, "block", BlockOnly: true);

    // ---- enheter ----
    private string UnitSym => unit == Unit.Mm ? "mm" : "\"";
    private double Step => unit == Unit.Mm ? 1 : 0.25;
    private double DispMin => unit == Unit.Mm ? 50 : 2;
    private double DispMax => unit == Unit.Mm ? 510 : 20;
    private double TMin => unit == Unit.Mm ? 13 : 0.5;
    private double TMax => unit == Unit.Mm ? 300 : 12;
    private double WMin => unit == Unit.Mm ? 13 : 0.5;
    private double WMax => unit == Unit.Mm ? 520 : 20;

    private static double Round(double v) => Math.Round(v, 2);
    private double ToDisplay(double inch) => unit == Unit.Mm ? inch * SawConstants.MmPerInch : inch;
    private double FromDisplay(double disp) => unit == Unit.Mm ? disp / SawConstants.MmPerInch : disp;

    private double FubDisplay
    {
        get => unit == Unit.Mm ? Math.Round(fub * SawConstants.MmPerInch) : Math.Round(fub, 2);
        set { fub = unit == Unit.Mm ? value / SawConstants.MmPerInch : value; Recalculate(); }
    }
    private double ThicknessDisplay { get => Round(ToDisplay(thickness)); set { thickness = FromDisplay(value); Recalculate(); } }
    private double WidthDisplay { get => Round(ToDisplay(width)); set { width = FromDisplay(value); Recalculate(); } }

    private string U(Measure m) => unit == Unit.Mm ? $"{m.Millimeters:0} mm" : $"{m.Inches:0.##}\"";
    private string Other(double inch) => unit == Unit.Mm ? $"{inch:0.##}\"" : $"{inch * SawConstants.MmPerInch:0.#} mm";

    private string Dim => $"{U(thickness)}×{U((Measure)width)}";

    private bool WidthAny { get => widthAny; set { widthAny = value; Recalculate(); } }
    private bool ThicknessAny { get => thicknessAny; set { thicknessAny = value; Recalculate(); } }

    private int Yield(TargetResult row)
        => PostningMetrics.YieldPercent(row.Postning, row.TargetPieceCount * row.TargetThickness.Inches * row.ActualBlockWidth.Inches);

    protected override void OnInitialized()
    {
        Saw.Changed += OnSettingsChanged;
        if (Nav.Uri.Contains("/mal", StringComparison.OrdinalIgnoreCase)) mode = Mode.Dim;
        Recalculate();
    }

    private void OnSettingsChanged() { Recalculate(); StateHasChanged(); }
    public void Dispose() => Saw.Changed -= OnSettingsChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var s = await JS.InvokeAsync<string?>("appStore.get", "pmState");
        if (!string.IsNullOrEmpty(s))
        {
            try
            {
                var d = JsonSerializer.Deserialize<State>(s);
                if (d is not null)
                {
                    if (!Nav.Uri.Contains("/mal", StringComparison.OrdinalIgnoreCase)) mode = (Mode)d.Mode;
                    unit = (Unit)d.U; fub = d.Fub; thickness = d.T; width = d.W;
                    thicknessAny = d.TA; widthAny = d.WA;
                }
            }
            catch { /* ignorera trasig cache */ }
        }
        ready = true;
        Recalculate();
        StateHasChanged();
    }

    private void SetMode(Mode m) { mode = m; Recalculate(); }
    private void SetUnit(Unit u) { unit = u; Persist(); }
    private void PickWidth(double w) { width = w; widthAny = false; Recalculate(); }

    private void Nudge(int dir)
    {
        if (unit == Unit.Mm)
        {
            double mm = Math.Round(fub * SawConstants.MmPerInch) + dir * 5;
            fub = Math.Clamp(mm, 50, 510) / SawConstants.MmPerInch;
        }
        else
        {
            double inch = Math.Round((fub + dir * 0.25) / 0.25) * 0.25;
            fub = Math.Clamp(inch, 2, 20);
        }
        Recalculate();
    }

    private void Recalculate()
    {
        Persist();
        stockResult = null; stockError = null;
        result = null; widthTable = null; cant = null;

        if (mode == Mode.Stock)
        {
            try { stockResult = PostningsMax.Compute(fub, Saw.KerfInches, Saw.ClampHeightMm / SawConstants.MmPerInch); }
            catch (ArgumentOutOfRangeException ex) { stockError = ex.Message.Split('(')[0].Trim(); }
            return;
        }

        if (thicknessAny && widthAny) return;
        if (widthAny) { if (thickness > 0) widthTable = TargetDimension.ByWidth(thickness, Saw.KerfInches); }
        else if (thicknessAny) { if (width > 0) cant = TargetDimension.SmallestStockForWidth(width, Saw.KerfInches); }
        else if (width > 0 && thickness > 0) result = TargetDimension.Compute(width, thickness, Saw.KerfInches);
    }

    private void Persist()
    {
        if (!ready) return;
        var d = new State { Mode = (int)mode, U = (int)unit, Fub = fub, T = thickness, W = width, TA = thicknessAny, WA = widthAny };
        _ = JS.InvokeVoidAsync("appStore.set", "pmState", JsonSerializer.Serialize(d));
    }

    private sealed class State
    {
        public int Mode { get; set; }
        public int U { get; set; }
        public double Fub { get; set; } = 9.75;
        public double T { get; set; } = 2;
        public double W { get; set; } = 6;
        public bool TA { get; set; }
        public bool WA { get; set; }
    }
}
