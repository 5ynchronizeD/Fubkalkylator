@page "/mal"
@inject SawSettings Saw
@inject IJSRuntime JS
@using System.Text.Json

<PageTitle>Måldimension</PageTitle>

<div class="page-head">
    <h1>Måldimension</h1>
    <p>Ange dimensionen du vill få ut. Låt appen räkna fram minsta stock — eller mata in din egen stock och se hur du kapar ut den.</p>
</div>

<div class="seg mode">
    <button type="button" class="@(mode == Mode.MinStock ? "on" : null)" @onclick="() => SetMode(Mode.MinStock)">Räkna ut minsta stock</button>
    <button type="button" class="@(mode == Mode.MyStock ? "on" : null)" @onclick="() => SetMode(Mode.MyStock)">Jag har en stock</button>
</div>

<div class="input-bar">
    <div class="bar-top">
        <label>@(mode == Mode.MyStock ? "Min stock & måldimension" : "Jag vill ha")</label>
        <div class="seg small">
            <button type="button" class="@(unit == Unit.Inch ? "on" : null)" @onclick="() => SetUnit(Unit.Inch)">tum</button>
            <button type="button" class="@(unit == Unit.Mm ? "on" : null)" @onclick="() => SetUnit(Unit.Mm)">mm</button>
        </div>
    </div>

    <div class="target-row">
        @if (mode == Mode.MyStock)
        {
            <div class="dim-field stock">
                <div class="value-box">
                    <input type="number" step="@Step" min="@WMin" max="@WMax" @bind="StockDisplay" @bind:event="oninput" />
                    <span class="unit">@UnitSym</span>
                </div>
                <small>stock fub · @Other(stock)</small>
            </div>
            <span class="times">→</span>
        }
        <div class="dim-field">
            <div class="value-box">
                <input type="number" step="@Step" min="@TMin" max="@TMax" disabled="@thicknessAny"
                       @bind="ThicknessDisplay" @bind:event="oninput" />
                <span class="unit">@UnitSym</span>
            </div>
            <small>tjock @(thicknessAny ? "" : $"· {Other(thickness)}")</small>
            <label class="any"><input type="checkbox" @bind="ThicknessAny" /> spelar ingen roll</label>
        </div>
        <span class="times">×</span>
        <div class="dim-field">
            <div class="value-box">
                <input type="number" step="@Step" min="@WMin" max="@WMax" disabled="@widthAny"
                       @bind="WidthDisplay" @bind:event="oninput" />
                <span class="unit">@UnitSym</span>
            </div>
            <small>bred @(widthAny ? "" : $"· {Other(width)}")</small>
            <label class="any"><input type="checkbox" @bind="WidthAny" /> spelar ingen roll</label>
        </div>
    </div>
    <KerfControl OnChanged="Recalculate" />
</div>

@if (thicknessAny && widthAny && mode == Mode.MinStock)
{
    <div class="banner warn">Ange minst ett mått — annars finns inget att optimera.</div>
}
else if (mode == Mode.MyStock)
{
    @if (stockTooSmall)
    {
        <div class="banner warn">Stocken är för klen för att ge ett block. Ange en grövre stock.</div>
    }
    else if (thicknessAny && myCant is not null)
    {
        <div class="banner">
            Ur din stock (@U((Measure)stock) fub) blir blocket <strong>@U(myCant.BlockWidth) × @U(myCant.BlockHeight)</strong> — klyv i valfri tjocklek.
        </div>
        @ResultGrid(myCant, WholeBlock(myCant), 0, true, "block",
                    PostningMetrics.YieldPercent(myCant, myCant.BlockWidth.Inches * myCant.BlockHeight.Inches))
    }
    else if (fit is not null && !fit.WidthFits)
    {
        <div class="banner warn">
            @U((Measure)width) är för brett för den här stocken. Största bredd du får ur blocket är <strong>@U(fit.MaxWidth)</strong>.
        </div>
    }
    else if (fit is not null)
    {
        <div class="banner">
            Ur din stock (@U((Measure)stock) fub) får du <strong>@fit.PieceCount st @DimFor(FitWidth)</strong>.
            @if (fit.TrimWidthInches > 0.001)
            {
                <span class="trim">Blocket är @U(fit.MaxWidth) brett – kapas @U((Measure)fit.TrimWidthInches) till målbredd.</span>
            }
        </div>
        @ResultGrid(fit.Postning, fit.BlockPieces, fit.PieceCount, false, DimFor(FitWidth),
                    PostningMetrics.YieldPercent(fit.Postning, fit.PieceCount * thickness * FitWidth))
        <SaveJobForm StockFub="fit.Postning.DiameterUnderBark.Inches" Kerf="fit.Postning.KerfInches"
                     TargetThickness="thickness" TargetWidth="FitWidth"
                     BlockWidth="fit.Postning.BlockWidth.Inches" BlockHeight="fit.Postning.BlockHeight.Inches"
                     CalculatedOutcome="@($"{fit.PieceCount} st {DimFor(FitWidth)}")" />
        <SawScheduleCard Result="fit.Postning" BlockPieces="fit.BlockPieces" />
        <StepSawVisual Result="fit.Postning" BlockPieces="fit.BlockPieces" />
    }
}
else if (widthAny)
{
    @if (widthTable is { Count: > 0 })
    {
        <div class="banner">Bredden är fri. Välj en bredd nedan för att se ritningen.</div>
        <div class="card">
            <div class="card-title">Alternativ · @U(thickness) tjocka bitar</div>
            <table class="opt">
                <thead><tr><th>Bredd</th><th>Minsta stock</th><th>Antal</th><th>Utbyte</th><th></th></tr></thead>
                <tbody>
                    @foreach (var row in widthTable)
                    {
                        <tr @onclick="() => PickWidth(row.ActualBlockWidth.Inches)">
                            <td>@U(row.ActualBlockWidth)</td>
                            <td>@U(row.Postning.DiameterUnderBark)</td>
                            <td>@row.TargetPieceCount st</td>
                            <td>@Yield(row) %</td>
                            <td class="go">visa ›</td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="hint">Utbyte = andel av stockens area som blir virke (inkl. sido-/ändbrädor). Resten är spill.</p>
        </div>
    }
    else
    {
        <div class="banner warn">Den tjockleken går inte att få ut inom @U((Measure)20.0) stock.</div>
    }
}
else if (thicknessAny)
{
    @if (cant is not null)
    {
        <div class="banner">
            Minsta stock för <strong>@U(width) bred</strong> är <strong>@U(cant.DiameterUnderBark) fub</strong>.
            Blocket blir <strong>@U(cant.BlockWidth) × @U(cant.BlockHeight)</strong> och kan klyvas i valfri tjocklek.
        </div>
        @ResultGrid(cant, WholeBlock(cant), 0, true, "block",
                    PostningMetrics.YieldPercent(cant, cant.BlockWidth.Inches * cant.BlockHeight.Inches))
    }
    else
    {
        <div class="banner warn">Den bredden går inte att få ut inom @U((Measure)20.0) stock.</div>
    }
}
else if (result is not null)
{
    <div class="banner">
        Du får <strong>@result.TargetPieceCount st @Dim</strong> ur en stock på
        minst <strong>@U(result.Postning.DiameterUnderBark) fub</strong>
        (≈ @U(result.TopDiameterOverBark) på bark).
        @if (result.TrimWidthInches > 0.001)
        {
            <span class="trim">Blocket blir @U(result.ActualBlockWidth) brett – kapas @U((Measure)result.TrimWidthInches) till målbredd.</span>
        }
    </div>
    @ResultGrid(result.Postning, result.BlockPieces, result.TargetPieceCount, false, Dim, ResultYield)
    <SaveJobForm StockFub="result.Postning.DiameterUnderBark.Inches" Kerf="result.Postning.KerfInches"
                 TargetThickness="thickness" TargetWidth="width"
                 BlockWidth="result.Postning.BlockWidth.Inches" BlockHeight="result.Postning.BlockHeight.Inches"
                 CalculatedOutcome="@($"{result.TargetPieceCount} st {Dim}")" />
    <SawScheduleCard Result="result.Postning" BlockPieces="result.BlockPieces" />
    <StepSawVisual Result="result.Postning" BlockPieces="result.BlockPieces" />
}
else
{
    <div class="banner warn">Den dimensionen går inte att få ut inom @U((Measure)20.0) stock. Prova mindre mått.</div>
}

<ShrinkageCard />

@code {
    private enum Unit { Inch, Mm }
    private enum Mode { MinStock, MyStock }

    private double width = 6, thickness = 2, stock = 12;
    private bool widthAny = false, thicknessAny = false;
    private Unit unit = Unit.Inch;
    private Mode mode = Mode.MinStock;

    private TargetResult? result;
    private IReadOnlyList<TargetResult>? widthTable;
    private PostningResult? cant;
    private FitResult? fit;
    private PostningResult? myCant;
    private bool stockTooSmall;

    // ---- enheter ----
    private string UnitSym => unit == Unit.Mm ? "mm" : "\"";
    private double Step => unit == Unit.Mm ? 1 : 0.25;
    private double TMin => unit == Unit.Mm ? 13 : 0.5;
    private double TMax => unit == Unit.Mm ? 300 : 12;
    private double WMin => unit == Unit.Mm ? 13 : 0.5;
    private double WMax => unit == Unit.Mm ? 520 : 20;

    private double ToDisplay(double inch) => unit == Unit.Mm ? inch * SawConstants.MmPerInch : inch;
    private double FromDisplay(double disp) => unit == Unit.Mm ? disp / SawConstants.MmPerInch : disp;
    private static double Round(double v) => Math.Round(v, 2);

    private double ThicknessDisplay { get => Round(ToDisplay(thickness)); set { thickness = FromDisplay(value); Recalculate(); } }
    private double WidthDisplay { get => Round(ToDisplay(width)); set { width = FromDisplay(value); Recalculate(); } }
    private double StockDisplay { get => Round(ToDisplay(stock)); set { stock = FromDisplay(value); Recalculate(); } }

    private void SetUnit(Unit u) { unit = u; }
    private void SetMode(Mode m) { mode = m; Recalculate(); }

    private bool WidthAny { get => widthAny; set { widthAny = value; Recalculate(); } }
    private bool ThicknessAny { get => thicknessAny; set { thicknessAny = value; Recalculate(); } }

    private double FitWidth => widthAny && fit is not null ? fit.MaxWidth.Inches : width;
    private string Dim => DimFor(width);
    private string DimFor(double w) => $"{U(thickness)}×{U((Measure)w)}";

    private bool ready;

    protected override void OnInitialized() => Recalculate();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var s = await JS.InvokeAsync<string?>("appStore.get", "malState");
        if (!string.IsNullOrEmpty(s))
        {
            try
            {
                var d = JsonSerializer.Deserialize<MalState>(s);
                if (d is not null)
                {
                    thickness = d.T; width = d.W; thicknessAny = d.TA; widthAny = d.WA;
                    unit = (Unit)d.U; mode = (Mode)d.M; stock = d.S;
                    Recalculate();
                    StateHasChanged();
                }
            }
            catch { /* ignorera trasig cache */ }
        }
        ready = true;
    }

    private void PickWidth(double w) { width = w; widthAny = false; Recalculate(); }

    private void Persist()
    {
        if (!ready) return;
        var d = new MalState { T = thickness, W = width, TA = thicknessAny, WA = widthAny, U = (int)unit, M = (int)mode, S = stock };
        _ = JS.InvokeVoidAsync("appStore.set", "malState", JsonSerializer.Serialize(d));
    }

    private void Recalculate()
    {
        Persist();
        result = null; widthTable = null; cant = null; fit = null; myCant = null; stockTooSmall = false;

        if (mode == Mode.MyStock)
        {
            if (stock <= 0) return;
            PostningResult? p;
            try { p = PostningsMax.Compute(stock, Saw.KerfInches); }
            catch (ArgumentOutOfRangeException) { stockTooSmall = true; return; }

            if (thicknessAny) { myCant = p; return; }
            double w = widthAny ? p!.BlockWidth.Inches : width;
            if (w > 0 && thickness > 0) fit = TargetDimension.FitInStock(stock, w, thickness, Saw.KerfInches);
            return;
        }

        if (thicknessAny && widthAny) return;
        if (widthAny) { if (thickness > 0) widthTable = TargetDimension.ByWidth(thickness, Saw.KerfInches); }
        else if (thicknessAny) { if (width > 0) cant = TargetDimension.SmallestStockForWidth(width, Saw.KerfInches); }
        else if (width > 0 && thickness > 0) result = TargetDimension.Compute(width, thickness, Saw.KerfInches);
    }

    // ---- utbyte ----
    private int Yield(TargetResult row)
        => PostningMetrics.YieldPercent(row.Postning,
            row.TargetPieceCount * row.TargetThickness.Inches * row.ActualBlockWidth.Inches);
    private int ResultYield => result is null ? 0 : Yield(result);

    private static IReadOnlyList<Piece> WholeBlock(PostningResult r)
        => new[] { new Piece(0, r.BlockHeight.Inches, BoardKind.Target) };

    private static IEnumerable<(int Count, string Label)> ByProducts(PostningResult r)
    {
        if (r.SideTwoInchBoards > 0) yield return (r.SideTwoInchBoards, "2\"-sidoreglar/plank");
        if (r.SideOneInchBoards > 0) yield return (r.SideOneInchBoards, "1\"-sidobrädor");
        if (r.EndTwoInchBoards > 0) yield return (r.EndTwoInchBoards, "2\"-ändreglar/plank");
        if (r.EndOneInchBoards > 0) yield return (r.EndOneInchBoards, "1\"-ändbrädor");
    }

    private string U(Measure m) => unit == Unit.Mm ? $"{m.Millimeters:0} mm" : $"{m.Inches:0.##}\"";
    private string Other(double inch) => unit == Unit.Mm ? $"{inch:0.##}\"" : $"{inch * SawConstants.MmPerInch:0.#} mm";

    // Cachat sidtillstånd (sparas i localStorage).
    private sealed class MalState
    {
        public double T { get; set; } = 2;
        public double W { get; set; } = 6;
        public bool TA { get; set; }
        public bool WA { get; set; }
        public int U { get; set; }
        public int M { get; set; }
        public double S { get; set; } = 12;
    }

    // Gemensam resultatvy (ritning + chips + ev. lista).
    private RenderFragment ResultGrid(PostningResult p, IReadOnlyList<Piece> pieces, int pieceCount,
        bool blockOnly, string dimLabel, int yield) => __builder =>
    {
        <div class="result-grid">
            <div class="card figure-card">
                <div class="card-title">Stockände</div>
                <LogCrossSection Result="p" BlockPieces="pieces" />
                <div class="legend">
                    <span><i class="sw" style="background:#c07d33"></i> @(blockOnly ? "block (klyv fritt)" : "din dimension")</span>
                    @if (!blockOnly)
                    {
                        <span><i class="sw" style="background:#e3b466"></i> sido-/ändbräda 1"</span>
                        <span><i class="sw" style="background:#b06a2c"></i> sido-/ändregel 2"</span>
                    }
                </div>
            </div>
            <div class="side-col">
                <div class="chips">
                    <div class="chip"><span>Stock (fub)</span><strong>@U(p.DiameterUnderBark)</strong></div>
                    <div class="chip"><span>Block B×H</span><strong>@U(p.BlockWidth) × @U(p.BlockHeight)</strong></div>
                    <div class="chip"><span>Utbyte</span><strong>@yield %</strong></div>
                </div>
                @if (!blockOnly)
                {
                    <div class="card">
                        <div class="card-title">Vad du får ut</div>
                        <ul class="mat">
                            <li class="hi"><span class="q">@pieceCount st</span><span class="d">@dimLabel (ur blocket)</span></li>
                            @foreach (var line in ByProducts(p))
                            {
                                <li><span class="q">@line.Count st</span><span class="d">@line.Label</span></li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    };
}
